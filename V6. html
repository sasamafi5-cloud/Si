<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#e8edf3">
<title>Ana – AI Sekretarica</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#e8edf3;--tx:#2a3a4a;--tx2:#2a3a4a55;--ac:#00c8b4;
  --dark:#b8c5d0;--light:#ffffff;--r:16px;
}
body{background:var(--bg);color:var(--tx);font-family:'Segoe UI',Arial,sans-serif;min-height:100vh;transition:background .3s,color .3s;overflow-x:hidden;-webkit-font-smoothing:antialiased}
.c{background:var(--bg);box-shadow:6px 6px 14px var(--dark),-6px -6px 14px var(--light);border-radius:var(--r)}
.i{background:var(--bg);box-shadow:inset 4px 4px 10px var(--dark),inset -4px -4px 10px var(--light);border-radius:12px}
.b{background:var(--bg);box-shadow:4px 4px 10px var(--dark),-4px -4px 10px var(--light);border-radius:50px;border:none;cursor:pointer;color:var(--tx);font-family:inherit;transition:all .2s;outline:none}
.b:active{box-shadow:inset 3px 3px 8px var(--dark),inset -3px -3px 8px var(--light)}
input,textarea,select{background:var(--bg);box-shadow:inset 4px 4px 10px var(--dark),inset -4px -4px 10px var(--light);border-radius:12px;border:none;color:var(--tx);font-family:inherit;outline:none;width:100%;padding:10px 14px;font-size:13px}
#app{max-width:480px;margin:0 auto;padding:0 0 20px}

/* HEADER */
.hdr{padding:14px 14px 0;display:flex;justify-content:space-between;align-items:flex-start}
.clk{font-size:28px;font-weight:900;letter-spacing:-1px}
.dbar{padding:4px 14px 8px;font-size:12px;font-weight:700;color:var(--ac)}
.tabs{display:inline-flex;gap:2px;padding:5px 6px}
.tb{padding:7px 11px;font-size:12px;font-weight:700;border-radius:50px;border:none;cursor:pointer;font-family:inherit;background:transparent;box-shadow:none;color:var(--tx2);transition:all .2s}
.tb.on{background:var(--bg);box-shadow:4px 4px 10px var(--dark),-4px -4px 10px var(--light);color:var(--ac)}

/* ANA CARD */
.ana-card{margin:10px 12px;padding:14px;display:flex;align-items:center;gap:12px}
.ana-av{width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,var(--ac),#00a896);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;box-shadow:0 4px 18px #00c8b455;transition:all .3s}
.ana-av.talking{animation:avpulse 0.6s ease-in-out infinite alternate;box-shadow:0 0 28px #00c8b488,0 0 50px #00c8b433}
.ana-av.listening{box-shadow:0 0 28px #ff7eb388,0 0 50px #ff7eb333;animation:avpulse2 0.4s ease-in-out infinite alternate}
@keyframes avpulse{from{transform:scale(1)}to{transform:scale(1.1)}}
@keyframes avpulse2{from{transform:scale(0.97)}to{transform:scale(1.06)}}
@keyframes si{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes dotani{0%,100%{height:4px;opacity:.4}50%{height:20px;opacity:1}}
@keyframes ringpulse{0%{transform:scale(1);opacity:.8}100%{transform:scale(1.6);opacity:0}}
@keyframes waveani{0%,100%{scaleY:.3}50%{scaleY:1}}

/* VOICE RINGS */
.voice-rings{position:relative;width:80px;height:80px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ring{position:absolute;border-radius:50%;border:2px solid var(--ac);opacity:0}
.ring1{width:80px;height:80px}
.ring2{width:100px;height:100px}
.ring3{width:120px;height:120px}
.active .ring1{animation:ringpulse 1.5s ease-out infinite}
.active .ring2{animation:ringpulse 1.5s ease-out .3s infinite}
.active .ring3{animation:ringpulse 1.5s ease-out .6s infinite}

/* WAVEFORM */
.waveform{display:flex;align-items:center;gap:3px;height:32px;margin:8px 0}
.wave-bar{width:3px;border-radius:3px;background:var(--ac);height:4px;transition:height .1s ease}
.waveform.active .wave-bar{animation:dotani .6s ease infinite}
.waveform.active .wave-bar:nth-child(2){animation-delay:.1s}
.waveform.active .wave-bar:nth-child(3){animation-delay:.2s}
.waveform.active .wave-bar:nth-child(4){animation-delay:.15s}
.waveform.active .wave-bar:nth-child(5){animation-delay:.05s}
.waveform.active .wave-bar:nth-child(6){animation-delay:.25s}
.waveform.active .wave-bar:nth-child(7){animation-delay:.1s}
.waveform.active .wave-bar:nth-child(8){animation-delay:.2s}

/* CHAT */
.chat-wrap{margin:0 12px 10px;position:relative}
.chat-box{padding:12px;min-height:200px;max-height:300px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;scroll-behavior:smooth}
.msg-row{display:flex;animation:si .25s ease}
.msg-row.u{justify-content:flex-end}
.msg-row.a{justify-content:flex-start;align-items:flex-end;gap:7px}
.av-sm{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--ac),#00a896);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.bubble{max-width:78%;padding:10px 14px;border-radius:18px;font-size:13px;line-height:1.55;word-break:break-word}
.bubble.u{background:linear-gradient(135deg,var(--ac),#00a896);color:#fff;border-radius:18px 18px 4px 18px;box-shadow:0 4px 14px #00c8b444}
.bubble.a{background:var(--bg);box-shadow:4px 4px 10px var(--dark),-4px -4px 10px var(--light);border-radius:18px 18px 18px 4px}
.dots-row{display:flex;gap:6px;padding:12px 14px;align-items:center}
.dot{width:7px;height:7px;border-radius:50%;background:var(--ac);animation:dotani .7s ease infinite alternate}
.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}

/* BIG MIC BUTTON */
.mic-center{display:flex;flex-direction:column;align-items:center;padding:8px 0 4px}
.mic-big-wrap{position:relative;display:flex;align-items:center;justify-content:center;width:120px;height:120px}
.mic-big{width:86px;height:86px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;background:var(--bg);box-shadow:8px 8px 20px var(--dark),-8px -8px 20px var(--light);position:relative;z-index:2}
.mic-big.listening{background:linear-gradient(135deg,#ff7eb3,#ff4da6)!important;box-shadow:0 0 30px #ff7eb388!important}
.mic-big.speaking{background:linear-gradient(135deg,var(--ac),#00a896)!important;box-shadow:0 0 30px #00c8b488!important}
.mic-label{font-size:11px;font-weight:700;color:var(--tx2);margin-top:6px;transition:color .3s}

/* INPUT BAR */
.inp-bar{margin:8px 12px;padding:8px;display:flex;gap:8px;align-items:center}
.inp-mic{width:40px;height:40px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;background:var(--bg);box-shadow:3px 3px 8px var(--dark),-3px -3px 8px var(--light);flex-shrink:0}
.send-btn{width:40px;height:40px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;background:var(--bg);box-shadow:3px 3px 8px var(--dark),-3px -3px 8px var(--light);flex-shrink:0}

/* QUICK SUGGESTIONS */
.sugg-wrap{display:flex;gap:6px;flex-wrap:wrap;margin:0 12px 10px}
.sugg{padding:7px 12px;font-size:10px;font-weight:700;color:var(--ac);border:none}

/* QUICK GRID */
.qgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:0 12px 10px}
.q-sec{padding:12px 11px}
.q-title{font-size:11px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:5px;color:var(--tx)}

/* SECTIONS */
.sec{margin:0 12px 10px;padding:14px}
.sec-title{font-size:13px;font-weight:800;margin-bottom:10px;color:var(--ac)}
.tline{padding:6px 9px;margin-bottom:4px;border-radius:0 10px 10px 0;border-left:3px solid}
.tgl{width:42px;height:24px;border-radius:12px;position:relative;cursor:pointer;flex-shrink:0;transition:background .3s}
.tgl-k{position:absolute;top:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:left .3s;box-shadow:0 1px 4px rgba(0,0,0,.25)}
#offbadge{position:fixed;top:6px;right:8px;background:#ff6644;color:#fff;font-size:10px;font-weight:800;padding:4px 10px;border-radius:20px;z-index:999;display:none}

/* SETTINGS */
.set-box{margin:0 12px 10px;padding:16px}
</style>
</head>
<body>
<div id="offbadge">OFFLINE</div>
<div id="app">

  <div class="hdr">
    <div>
      <div class="c tabs" id="tabbar">
        <button class="tb on" data-t="chat">Ana</button>
        <button class="tb" data-t="notes">Beleske</button>
        <button class="tb" data-t="alarmi">Alarmi</button>
        <button class="tb" data-t="termini">Termini</button>
      </div>
    </div>
    <div style="text-align:right">
      <div class="clk" id="clk">00:00</div>
      <div style="font-size:11px;color:var(--tx2);font-weight:600" id="uname-lbl">Sasa</div>
    </div>
  </div>
  <div class="dbar" id="dbar"></div>

  <!-- CHAT TAB -->
  <div id="t-chat">

    <!-- ANA PROFIL -->
    <div class="c ana-card">
      <div class="ana-av" id="ana-av">&#x1F469;&#x200D;&#x1F4BC;</div>
      <div style="flex:1">
        <div style="font-size:18px;font-weight:900">Ana</div>
        <div style="font-size:11px;color:var(--ac);font-weight:700" id="ana-status">&#x25CF; Dostupna</div>
        <div style="font-size:10px;color:var(--tx2);margin-top:2px">AI Sekretarica &bull; 100% Offline</div>
      </div>
      <button class="b" onclick="toggleSettings()" style="width:36px;height:36px;display:flex;align-items:center;justify-content:center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--tx)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>

    <!-- SETTINGS -->
    <div id="settings-box" style="display:none">
      <div class="c set-box">
        <div style="font-size:13px;font-weight:800;margin-bottom:10px;color:var(--ac)">Tema</div>
        <div style="display:flex;gap:8px;margin-bottom:14px">
          <button class="b" onclick="setTheme('light')" style="flex:1;padding:9px;font-size:11px;font-weight:700">Svetla</button>
          <button class="b" onclick="setTheme('dark')" style="flex:1;padding:9px;font-size:11px;font-weight:700">Tamna</button>
          <button class="b" onclick="setTheme('blue')" style="flex:1;padding:9px;font-size:11px;font-weight:700">Plava</button>
        </div>
        <div style="font-size:13px;font-weight:800;margin-bottom:10px;color:var(--ac)">Boja akcenta</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
          <div onclick="setAC('#00c8b4')" style="width:30px;height:30px;border-radius:50%;background:#00c8b4;cursor:pointer;box-shadow:2px 2px 6px rgba(0,0,0,.2)"></div>
          <div onclick="setAC('#6ab4ff')" style="width:30px;height:30px;border-radius:50%;background:#6ab4ff;cursor:pointer;box-shadow:2px 2px 6px rgba(0,0,0,.2)"></div>
          <div onclick="setAC('#ffb347')" style="width:30px;height:30px;border-radius:50%;background:#ffb347;cursor:pointer;box-shadow:2px 2px 6px rgba(0,0,0,.2)"></div>
          <div onclick="setAC('#ff7eb3')" style="width:30px;height:30px;border-radius:50%;background:#ff7eb3;cursor:pointer;box-shadow:2px 2px 6px rgba(0,0,0,.2)"></div>
          <div onclick="setAC('#b47eff')" style="width:30px;height:30px;border-radius:50%;background:#b47eff;cursor:pointer;box-shadow:2px 2px 6px rgba(0,0,0,.2)"></div>
        </div>
        <div style="font-size:13px;font-weight:800;margin-bottom:10px;color:var(--ac)">Ime</div>
        <div style="display:flex;gap:8px;margin-bottom:14px">
          <input id="name-inp" placeholder="Tvoje ime..." style="font-size:13px">
          <button class="b" onclick="saveName()" style="padding:10px 14px;font-size:12px;font-weight:700;color:var(--ac)">OK</button>
        </div>
        <div style="font-size:13px;font-weight:800;margin-bottom:10px;color:var(--ac)">Glas Ane</div>
        <div style="display:flex;gap:8px">
          <button class="b" onclick="testVoice()" style="flex:1;padding:9px;font-size:11px;font-weight:700;color:var(--ac)">Test glasa</button>
          <button class="b" onclick="D.vol=Math.min(1,D.vol+.1);save()" style="flex:1;padding:9px;font-size:11px;font-weight:700">+ Jace</button>
          <button class="b" onclick="D.vol=Math.max(0,D.vol-.1);save()" style="flex:1;padding:9px;font-size:11px;font-weight:700">- Tise</button>
        </div>
      </div>
    </div>

    <!-- QUICK GRID -->
    <div class="qgrid">
      <div class="c q-sec">
        <div class="q-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2.5" stroke-linecap="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Alarmi
        </div>
        <div id="qalarms"></div>
      </div>
      <div class="c q-sec">
        <div class="q-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Termini
        </div>
        <div id="qevents"></div>
      </div>
    </div>

    <!-- CHAT MESSAGES -->
    <div class="c chat-wrap">
      <div class="chat-box" id="chat-box"></div>
    </div>

    <!-- BIG MIC -->
    <div class="mic-center">
      <div class="mic-big-wrap" id="mic-rings-wrap">
        <div class="ring ring1" id="r1"></div>
        <div class="ring ring2" id="r2"></div>
        <div class="ring ring3" id="r3"></div>
        <button class="mic-big" id="mic-big" onclick="togMic()">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2" stroke-linecap="round" id="mic-ico"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </button>
      </div>
      <div class="waveform" id="waveform">
        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
        <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
        <div class="wave-bar"></div><div class="wave-bar"></div>
      </div>
      <div class="mic-label" id="mic-label">Pritisni da govoriš</div>
    </div>

    <!-- TEXT INPUT -->
    <div class="c inp-bar">
      <input id="chat-inp" placeholder="Ili ukucaj poruku..." onkeydown="if(event.key==='Enter'){var v=this.value;this.value='';handleInput(v)}" style="font-size:13px">
      <button class="send-btn" onclick="var v=document.getElementById('chat-inp').value;document.getElementById('chat-inp').value='';handleInput(v)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2.5" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>

    <!-- SUGGESTIONS -->
    <div class="sugg-wrap">
      <button class="b sugg" onclick="handleInput('Sta imam danas')">Sta imam danas?</button>
      <button class="b sugg" onclick="handleInput('Dodaj alarm za 8 sati')">Alarm 8:00</button>
      <button class="b sugg" onclick="handleInput('Koliko je sati')">Koliko je sati?</button>
      <button class="b sugg" onclick="handleInput('Moji zadaci')">Zadaci</button>
      <button class="b sugg" onclick="handleInput('Kakvo je vreme')">Vreme?</button>
      <button class="b sugg" onclick="handleInput('Dodaj zadatak kupi hleb')">Novi zadatak</button>
    </div>
  </div>

  <!-- BELESKE TAB -->
  <div id="t-notes" style="display:none">
    <div class="c sec">
      <div class="sec-title">Nova Beleska</div>
      <input id="nt" placeholder="Naziv beleske..." style="margin-bottom:8px">
      <textarea id="ni" placeholder="Stavke (svaka u novom redu)..." rows="3" style="padding:10px 14px;font-size:12px;resize:none;margin-bottom:8px;display:block"></textarea>
      <button class="b" onclick="addNote()" style="width:100%;padding:11px;font-size:13px;font-weight:700;color:var(--ac)">Sacuvaj</button>
    </div>
    <div id="notes-list"></div>
  </div>

  <!-- ALARMI TAB -->
  <div id="t-alarmi" style="display:none">
    <div class="c sec">
      <div class="sec-title">Novi Alarm</div>
      <input id="al" placeholder="Naziv alarma..." style="margin-bottom:8px">
      <input type="time" id="at" style="margin-bottom:8px">
      <select id="arep" style="margin-bottom:10px;font-size:12px">
        <option value="none">Jednom</option>
        <option value="daily">Svaki dan</option>
        <option value="weekdays">Radni dani</option>
        <option value="weekend">Vikend</option>
      </select>
      <button class="b" onclick="addAlarm()" style="width:100%;padding:11px;font-size:13px;font-weight:700;color:var(--ac)">Postavi Alarm</button>
    </div>
    <div id="alarms-list"></div>
  </div>

  <!-- TERMINI TAB -->
  <div id="t-termini" style="display:none">
    <div class="c sec">
      <div class="sec-title">Novi Termin</div>
      <input id="et" placeholder="Naziv termina..." style="margin-bottom:8px">
      <input type="date" id="ed" style="margin-bottom:8px">
      <input type="time" id="etm" style="margin-bottom:8px">
      <input id="eloc" placeholder="Lokacija (opciono)..." style="margin-bottom:8px">
      <button class="b" onclick="addEvent()" style="width:100%;padding:11px;font-size:13px;font-weight:700;color:var(--ac)">Dodaj Termin</button>
    </div>
    <div id="events-list"></div>
    <div class="c sec">
      <div class="sec-title">To-Do Lista</div>
      <div id="todo-list"></div>
      <div style="display:flex;gap:6px;margin-top:8px">
        <input id="tdi" placeholder="Novi zadatak..." style="font-size:12px;padding:8px 10px" onkeydown="if(event.key==='Enter')addTodo()">
        <button class="b" onclick="addTodo()" style="padding:8px 12px;font-size:18px;color:var(--ac);font-weight:900">+</button>
      </div>
    </div>
  </div>

</div>

<script>
// ═══════════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════════
const EVCOL=["#00c8b4","#6ab4ff","#ffb347","#ff7eb3","#b47eff"];

let D={
  notes:[{id:1,title:"Shopping lista",items:["Hleb","Mleko","Jaja"]},{id:2,title:"Ideje",items:["Plan A","Plan B"]}],
  alarms:[{id:1,label:"Jutarnji",time:"07:00",active:true,fired:false,rep:"none"},{id:2,label:"Trening",time:"18:30",active:true,fired:false,rep:"none"}],
  events:[{id:1,title:"Sastanak",time:"14:00",date:"",color:"#00c8b4",loc:""},{id:2,title:"Paket",time:"15:30",date:"",color:"#6ab4ff",loc:""}],
  todos:[{id:1,text:"Zavrsi izvestaj",done:false},{id:2,text:"Kupi mleko",done:false}],
  chat:[{r:"a",t:"Zdravo! Ja sam Ana, tvoja AI sekretarica. Radim potpuno offline. Možeš mi govoriti ili kucati. Recite šta vam treba!"}],
  theme:"light",ac:"#00c8b4",uname:"Sasa",vol:0.9,
  mem:{lastTopic:"",userName:"Sasa"},
};
try{const s=localStorage.getItem("ana_off");if(s){const p=JSON.parse(s);D=Object.assign({},D,p);}}catch(e){}
function save(){try{localStorage.setItem("ana_off",JSON.stringify(D));}catch(e){}}

// ═══════════════════════════════════════════════
// THEME
// ═══════════════════════════════════════════════
const THEMES={
  light:{bg:"#e8edf3",tx:"#2a3a4a",dark:"#b8c5d0",light:"#ffffff"},
  dark:{bg:"#1a2030",tx:"#e0eaf5",dark:"#0d1118",light:"#252f42"},
