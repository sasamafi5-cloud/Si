function init(){
  setTheme(D.theme||"light");
  document.documentElement.style.setProperty("--ac",D.ac||"#00c8b4");
  document.getElementById("uname-lbl").textContent=D.uname||"Sasa";
  if(document.getElementById("name-inp"))document.getElementById("name-inp").value=D.uname||"";
  renderAll();swTab("chat");
}
init();
</script>
