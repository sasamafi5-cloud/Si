// SPEECH SYNTHESIS – AUDIO PROCESSING
// ═══════════════════════════════════════════════
let voices=[];let isSpeaking=false;let synthQueue=[];
speechSynthesis.onvoiceschanged=()=>{voices=speechSynthesis.getVoices();};

function getBestVoice(){
  const all=speechSynthesis.getVoices();
  // Priority: srpski > hrvatski > bosanski > engleski ženski
  return all.find(v=>v.lang.startsWith("sr"))
    ||all.find(v=>v.lang.startsWith("hr"))
    ||all.find(v=>v.lang.startsWith("bs"))
    ||all.find(v=>v.name.toLowerCase().includes("female")||v.name.includes("Samantha")||v.name.includes("Google UK English Female"))
    ||all[0];
}

function anaSpeak(txt){
  if(!window.speechSynthesis)return;
  speechSynthesis.cancel();
  isSpeaking=true;
  setAnaState("speaking");

  // Split into sentences for more natural flow
  const sentences=txt.match(/[^.!?]+[.!?]*/g)||[txt];
  let i=0;
  function speakNext(){
    if(i>=sentences.length){isSpeaking=false;setAnaState("idle");return;}
    const u=new SpeechSynthesisUtterance(sentences[i].trim());
    u.lang="sr-RS";
    u.rate=0.88;   // Sporije = prirodnije
    u.pitch=1.05;  // Blago više = ženski glas
    u.volume=D.vol||0.9;
    const v=getBestVoice();if(v)u.voice=v;
    u.onend=()=>{i++;speakNext();};
    u.onerror=()=>{isSpeaking=false;setAnaState("idle");};
    speechSynthesis.speak(u);
  }
  speakNext();
}

function stopSpeaking(){
  speechSynthesis.cancel();
  isSpeaking=false;
  setAnaState("idle");
}

