let rec=null,isLis=false;
function togMic(){
  if(isSpeaking){stopSpeaking();return;}
  if(isLis){rec?.stop();return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){anaSpeak("Za prepoznavanje govora koristite Chrome browser.");return;}
  rec=new SR();
  rec.lang="sr-RS";rec.interimResults=true;rec.maxAlternatives=1;
  let final="";
  rec.onstart=()=>{isLis=true;final="";setAnaState("listening");};
  rec.onresult=e=>{
    const t=Array.from(e.results).map(r=>r[0].transcript).join("");
    if(e.results[e.results.length-1].isFinal){final=t;}
    // Show interim in input
    document.getElementById("chat-inp").value=t;
  };
  rec.onerror=()=>{isLis=false;setAnaState("idle");};
  rec.onend=()=>{
    isLis=false;
    const txt=final||document.getElementById("chat-inp").value;
    document.getElementById("chat-inp").value="";
    if(txt.trim().length>1){
      setAnaState("thinking");
      setTimeout(()=>handleInput(txt.trim()),300);
    }else{setAnaState("idle");}
  };
  rec.start();
}

