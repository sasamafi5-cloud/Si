function handleInput(txt){
  if(!txt||!txt.trim())return;
  const t=txt.trim();

  // Add user message
  D.chat.push({r:"u",t});
  renderChat();
  setAnaState("thinking");

  // Process with slight delay for natural feel
  setTimeout(()=>{
    const resp=processInput(t);
    D.chat.push({r:"a",t:resp});
    renderAll();save();
    anaSpeak(resp);
  },400);
}

function processInput(txt){
  const t=txt.toLowerCase().trim();
  const name=D.uname||"Sasa";
  const now=new Date();
  const h=now.getHours(),min=now.getMinutes();
  const timeStr=`${String(h).padStart(2,"0")}:${String(min).padStart(2,"0")}`;
  const days=["nedelja","ponedeljak","utorak","sreda","četvrtak","petak","subota"];
  const months=["januar","februar","mart","april","maj","jun","jul","avgust","septembar","oktobar","novembar","decembar"];
  const dayName=days[now.getDay()];
  const dateStr=`${now.getDate()}. ${months[now.getMonth()]} ${now.getFullYear()}`;

  // ── POZDRAV ──────────────────────────────────
  if(/^(zdravo|hej|ej|hi|cao|ciao|dobro jutro|dobro vece|dobar dan|bok)/.test(t)){
    const greeting=h<12?"Dobro jutro":h<18?"Dobar dan":"Dobro veče";
    const opts=[
      `${greeting}, ${name}! Kako mogu da vam pomognem danas?`,
      `${greeting}, ${name}! Ovde Ana, uvek na usluzi. Šta vam treba?`,
      `${greeting}! Kako ste danas, ${name}? Čime mogu da pomognem?`,
    ];
    return opts[Math.floor(Math.random()*opts.length)];
  }

  // ── VREME ────────────────────────────────────
  if(/koliko je sati|koje je vreme|vreme je|sati|sat/.test(t)){
    return `Sada je ${timeStr}, ${name}. ${h<12?"Još jutro!":h<14?"Podne je!":h<18?"Popodne je.":"Veče je."}`;
  }

  // ── DATUM ────────────────────────────────────
  if(/koji je datum|koji dan|datum|dan u nedelji/.test(t)){
    return `Danas je ${dayName}, ${dateStr}.`;
  }

  // ── STA IMAM DANAS ───────────────────────────
  if(/sta imam danas|šta imam|plan za danas|moj raspored|raspored|pregled dana/.test(t)){
    const todayAlarms=D.alarms.filter(a=>a.active).map(a=>`alarm ${a.label} u ${a.time}`);
    const todayEvents=D.events.map(e=>`${e.title} u ${e.time}`);
    const activeTodos=D.todos.filter(t=>!t.done).map(t=>t.text);
    let resp=`Evo vašeg plana za danas, ${name}:\n\n`;
    if(todayAlarms.length) resp+=`Alarmi: ${todayAlarms.join(", ")}.\n`;
    if(todayEvents.length) resp+=`Termini: ${todayEvents.join(", ")}.\n`;
    if(activeTodos.length) resp+=`Zadaci: ${activeTodos.slice(0,3).join(", ")}${activeTodos.length>3?` i još ${activeTodos.length-3}`:""}.`;
    if(!todayAlarms.length&&!todayEvents.length&&!activeTodos.length) resp="Danas nemate ništa zakazano. Slobodan dan!";
    return resp;
  }

  // ── DODAJ ALARM ──────────────────────────────
  const alarmMatch=t.match(/(?:dodaj|postavi|namesti|stavi)\s+(?:alarm|podsetnik|okidač)(?:\s+(?:za|u|na))?\s+(\d{1,2})(?::(\d{2}))?(?:\s*(ujutro|uveče|popodne|sati|sat|minuta|h))?/i);
  const alarmRelMatch=t.match(/(?:alarm|podsetnik)\s+za\s+(\d+)\s+(?:minut|min)/i);
  const alarmTimeMatch=t.match(/(?:za|u|na)\s+(\d{1,2}):(\d{2})/);

  if(alarmMatch||alarmRelMatch||alarmTimeMatch){
    let ah,am=0,label="Podsetnik";
    if(alarmRelMatch){
      const mins=parseInt(alarmRelMatch[1]);
      const t2=new Date(now.getTime()+mins*60000);
      ah=t2.getHours();am=t2.getMinutes();
      label=`Podsetnik za ${mins} minuta`;
    }else if(alarmMatch){
      ah=parseInt(alarmMatch[1]);
      am=alarmMatch[2]?parseInt(alarmMatch[2]):0;
      if(alarmMatch[3]&&/uvece|popodne/i.test(alarmMatch[3])&&ah<12)ah+=12;
    }else if(alarmTimeMatch){
      ah=parseInt(alarmTimeMatch[1]);
      am=parseInt(alarmTimeMatch[2]);
    }
    if(ah!==undefined){
      const timeF=`${String(ah).padStart(2,"0")}:${String(am).padStart(2,"0")}`;
      // Extract label from text
      const labelMatch=t.match(/(?:alarm|podsetnik)\s+(.+?)(?:\s+za|\s+u|\s+na|\s+\d)/i);
      if(labelMatch&&labelMatch[1].trim().length>1)label=labelMatch[1].trim();
      D.alarms.push({id:Date.now(),label,time:timeF,active:true,fired:false,rep:"none"});
      save();renderAll();
      return `Odlično, ${name}! Alarm "${label}" sam postavila za ${timeF}. Podsetiću vas na vreme!`;
    }
  }

  // ── BRISI ALARM ──────────────────────────────
  if(/obrisi|ukloni|izbriši|cancel|ukini/.test(t)&&/alarm|podsetnik/.test(t)){
    const match=t.match(/(?:obrisi|ukloni|izbriši)\s+alarm\s+(.+)/i);
    if(match){
      const name2=match[1].trim();
      const found=D.alarms.find(a=>a.label.toLowerCase().includes(name2));
      if(found){D.alarms=D.alarms.filter(a=>a.id!==found.id);save();renderAll();return `Alarm "${found.label}" je obrisan, ${name}.`;}
    }
    if(D.alarms.length===0)return `Nemate aktivnih alarma, ${name}.`;
    return `Koji alarm da obrišem? Imate: ${D.alarms.map(a=>a.label).join(", ")}.`;
  }

  // ── ALARMI PREGLED ───────────────────────────
  if(/alarmi|alarm|podsetnici|koji alarmi/.test(t)&&!/dodaj|postavi|stavi|obrisi/.test(t)){
    if(D.alarms.length===0)return `Nemate nijednog alarma, ${name}. Da podesim jedan?`;
    const aktiv=D.alarms.filter(a=>a.active);
    return `Vaši alarmi su, ${name}: ${aktiv.map(a=>`${a.label} u ${a.time}`).join(", ")}.${D.alarms.length>aktiv.length?" Neki su isključeni.":""}`;
  }

  // ── DODAJ BELEŠKU ────────────────────────────
  const noteMatch=t.match(/(?:dodaj|napravi|zapisi|sacuvaj|sačuvaj)\s+(?:belešku?|belesku|zapis|napomenu?)(?:\s+(?:pod\s+nazivom|nazvan[ao]?|pod\s+imenom))?\s*(.+)?/i);
  if(noteMatch){
    const title=noteMatch[1]?noteMatch[1].trim():"Nova beleška";
    D.notes.push({id:Date.now(),title,items:[]});
    save();renderAll();
    return `Beleška "${title}" je sačuvana, ${name}! Možete joj dodati stavke u tabu Beleske.`;
  }

  // ── BELESKE PREGLED ──────────────────────────
  if(/beleške?|beleska|zapis|belesku|moje beleske/.test(t)&&!/dodaj|napravi/.test(t)){
    if(D.notes.length===0)return `Nemate nijedne beleške, ${name}. Da napravim jednu?`;
    return `Imate ${D.notes.length} beleški: ${D.notes.map(n=>n.title).join(", ")}.`;
  }

  // ── DODAJ TERMIN ─────────────────────────────
  const eventMatch=t.match(/(?:dodaj|zakaži|zakazi|stavi|napravi)\s+(?:termin|sastanak|meeting|obavezu?)\s+(.+?)(?:\s+(?:za|u|na)\s+(\d{1,2})(?::(\d{2}))?)?$/i);
  if(eventMatch){
    const title=eventMatch[1]||"Termin";
    let eh=12,em=0;
    if(eventMatch[2]){eh=parseInt(eventMatch[2]);em=eventMatch[3]?parseInt(eventMatch[3]):0;}
    const timeF=`${String(eh).padStart(2,"0")}:${String(em).padStart(2,"0")}`;
    D.events.push({id:Date.now(),title,time:timeF,date:"",color:EVCOL[Math.floor(Math.random()*EVCOL.length)],loc:""});
    save();renderAll();
    return `Termin "${title}" sam zakazala za ${timeF}, ${name}. Podsetiću vas!`;
  }

  // ── TERMINI PREGLED ──────────────────────────
  if(/termini|termin|sastanci|raspored|kalendar|moji termini/.test(t)&&!/dodaj|zakazi/.test(t)){
    if(D.events.length===0)return `Nemate zakazanih termina, ${name}.`;
    return `Vaši termini su: ${D.events.map(e=>`${e.title} u ${e.time}`).join(", ")}.`;
  }

  // ── DODAJ ZADATAK ────────────────────────────
  const todoMatch=t.match(/(?:dodaj|napravi|stavi|zapisi)\s+(?:zadatak|obavezu?|to-do|todo)\s+(.+)/i);
  if(todoMatch){
    const text=todoMatch[1].trim();
    D.todos.push({id:Date.now(),text,done:false});
    save();renderTodos();
    return `Zadatak "${text}" je dodat na listu, ${name}!`;
  }

  // ── TODOS PREGLED ────────────────────────────
  if(/zadaci|zadatak|obaveze|to-do|lista|šta treba|sta treba/.test(t)&&!/dodaj/.test(t)){
    const active=D.todos.filter(t=>!t.done);
    const done=D.todos.filter(t=>t.done);
    if(D.todos.length===0)return `Lista zadataka je prazna, ${name}. Uživajte u slobodnom vremenu!`;
    let resp=`Imate ${active.length} aktivnih zadataka, ${name}: ${active.slice(0,4).map(t=>t.text).join(", ")}`;
    if(done.length>0)resp+=`. Završili ste ${done.length} zadataka. Bravo!`;
    return resp;
  }

  // ── HVALA ────────────────────────────────────
  if(/hvala|thanks|thank you|super|odlično|sjajno|bravo|ok|važi/.test(t)){
    const opts=[
      `Nema na čemu, ${name}! Tu sam za sve što vam treba.`,
      `Uvek mi je drago da pomognem, ${name}!`,
      `Molim! Ako vam šta treba, samo recite.`,
    ];
    return opts[Math.floor(Math.random()*opts.length)];
  }

  // ── KAKO SI ──────────────────────────────────
  if(/kako si|kako ste|jesi li dobro|kako ide/.test(t)){
    return `Odlična sam, hvala što pitaste, ${name}! Uvek sam tu i uvek u dobroj formi. A vi kako ste?`;
  }

  // ── KO SI TI ─────────────────────────────────
  if(/ko si|ko ste|predstavi se|kako se zoves|opis/.test(t)){
    return `Ja sam Ana, vaša personalna AI sekretarica! Mogu da vodim vaše alarme, beleške, termine i zadatke. Radim potpuno offline, bez interneta. Uvek dostupna za ${name}!`;
  }

  // ── ŠTA UMEŠ ─────────────────────────────────
  if(/šta umeš|sta umes|pomozi mi|komande|funkcije|sta znas|šta znaš|sta mozes|šta možeš/.test(t)){
    return `Mogu da vam pomognem sa svim ovim, ${name}: postaviti alarm ili podsetnik, sačuvati belešku, zakazati termin, dodati zadatak na listu, reći vam koje je vreme ili datum, pregledati vaš plan za dan, i još mnogo toga! Samo recite šta vam treba.`;
  }

  // ── VREME/TEMPERATURA ────────────────────────
  if(/kakvo je vreme|temperatura|prognoza|kisa|sunce|oblacno/.test(t)){
    return `Za informacije o vremenu potreban mi je internet, ${name}. Radim u offline modu. Preporučujem da pogledate vremensku prognozu u browseru.`;
  }

  // ── ŠALA / VIC ───────────────────────────────
  if(/ispricaj vic|šala|issmej me|šaljivo|reci nesto smesno/.test(t)){
    const vics=[
      "Zašto kompjuteri ne mogu da pevaju? Jer uvek zaštekaju na visokim notama!",
      "Pitao čovek robota: Jesi li srećan? Robot odgovorio: Da, 1!",
      "Programer ide u prodavnicu. Žena mu kaže: Uzmi litar mleka, a ako ima jaja - uzmi desetak. Vratio se sa deset litara mleka jer je bilo jaja.",
    ];
    return vics[Math.floor(Math.random()*vics.length)];
  }

  // ── BRISANJE SVEGA ───────────────────────────
  if(/obrisi sve|pocetak|reset|pocni ispocetka/.test(t)){
    return `Da li ste sigurni da želite da obrišete sve podatke, ${name}? Ako da, idite u Podešavanja i potvrdite brisanje.`;
  }

  // ── ZBOGOM ───────────────────────────────────
  if(/dovidjenja|cao|zbogom|pa vidimo se|laku noc|laku noć|cujemo se/.test(t)){
    return `${h>=20?"Laku noć":"Do viđenja"}, ${name}! Lepo se odmorite. Kada zatrebam, tu sam!`;
  }

  // ── FALLBACK – PRIRODNI ODGOVORI ─────────────
  const fallbacks=[
    `Razumem, ${name}. Mogu da vam pomognem sa alarmima, beleškama, terminima i zadacima. Šta od toga vam treba?`,
    `Hmm, nisam sasvim sigurna šta mislite, ${name}. Možete reći "dodaj alarm", "nova beleška", "zakaži termin" ili "dodaj zadatak".`,
    `Izvините, ${name}, to ne razumem dobro. Ali tu sam! Recite mi konkretno šta trebate.`,
    `Zanima me šta ste rekli, ${name}, ali nisam razumela. Možete li drugačije da formulišete?`,
  ];
  D.mem.lastTopic=txt;
  return fallbacks[Math.floor(Math.random()*fallbacks.length)];
}

